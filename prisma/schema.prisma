generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SuperAdmin {
  id          String   @id @default(uuid())
  fullName    String
  companyName String
  email       String   @unique
  phone       String   @unique
  userName    String   @unique
  passcode    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accountManagers AccountManager[]
  fieldManagers   FieldManager[]
  officeAdmins    OfficeAdmin[]
  projects        Project[]

  @@map("super_admins")
}

model AccountManager {
  id        String   @id @default(uuid())
  fullName  String
  userName  String   @unique
  passcode  String  
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  superAdminId String
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  projectAssignments ProjectAccountManager[]
  reviewedExpenses   Expense[]               @relation("ExpenseReviewer")

  @@map("account_managers")
}

model FieldManager {
  id        String   @id @default(uuid())
  fullName  String
  userName  String   @unique
  passcode  String   
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  superAdminId String
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  projectAssignments ProjectFieldManager[]
  expenses           Expense[]              @relation("FieldManagerExpenses")
  incomingTransfers  Expense[]              @relation("TransferRecipient")

  @@map("field_managers")
}

model OfficeAdmin {
  id        String   @id @default(uuid())
  fullName  String
  userName  String   @unique
  passcode  String   // hashed
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  superAdminId String
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  @@map("office_admins")
}

model Project {
  id        String   @id @default(uuid())
  name      String
  location  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  superAdminId String
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  fieldManagerAssignments   ProjectFieldManager[]
  accountManagerAssignments ProjectAccountManager[]
  expenses                  Expense[]

  @@map("projects")
}

model ProjectFieldManager {
  id             String   @id @default(uuid())
  projectId      String
  fieldManagerId String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fieldManager FieldManager @relation(fields: [fieldManagerId], references: [id], onDelete: Cascade)

  @@unique([projectId, fieldManagerId])
  @@map("project_field_managers")
}

model ProjectAccountManager {
  id               String   @id @default(uuid())
  projectId        String
  accountManagerId String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  accountManager AccountManager @relation(fields: [accountManagerId], references: [id], onDelete: Cascade)

  @@unique([projectId, accountManagerId])
  @@map("project_account_managers")
}

enum ExpenseStatus {
  PENDING
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
}

enum ExpenseMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  OTHER
}

enum PaidForCategory {
  MISCELLANEOUS   // Futkar Kharch
  TRAVEL          // Yatra Kharch
  PURCHASE        // Futkar Khareed
  GST_INVOICE     // Gst Invoice
  STAFF_PAYMENT   // Payment to Staff
  TRANSFER        // Transfer to Staff
  RETURN_TO_FIRM  // Returns to Firm
}

enum TransferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Expense {
  id               String        @id @default(uuid())
  projectId        String
  fieldManagerId   String
  submittedAmount  Float
  approvedAmount   Float?
  reimbursedAmount Float         @default(0)
  status           ExpenseStatus @default(PENDING)
  mode             ExpenseMode
  receiver         String
  paidFor          PaidForCategory
  description      String?
  expenseDate      DateTime      @default(now())

  reviewedByAccountManagerId String?
  reviewedByAccountManager   AccountManager? @relation("ExpenseReviewer", fields: [reviewedByAccountManagerId], references: [id])

  // Transfer-specific fields (only set when paidFor = TRANSFER)
  transferToFieldManagerId String?
  transferToFieldManager   FieldManager?   @relation("TransferRecipient", fields: [transferToFieldManagerId], references: [id])
  transferStatus           TransferStatus?
  transferRespondedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fieldManager FieldManager @relation("FieldManagerExpenses", fields: [fieldManagerId], references: [id], onDelete: Cascade)

  @@map("expenses")
}